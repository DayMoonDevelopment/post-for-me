# Post for Me e2e suite configuration.
#
# Copy this file to e2e/.env.local (auto-loaded, git-ignored) or `export` the
# variables before running `bun run test`. There is NO default target — the
# suite refuses to run unless API_BASE_URL and PFM_API_KEY are both set.

# --- Required -----------------------------------------------------------------

# Base URL of the API under test (no trailing slash, no /v1).
#   local:      http://localhost:3000   (run `bun run start:dev` in api/ first)
#   production: https://api.postforme.dev
API_BASE_URL=

# A real Post for Me API key (Unkey). The demo keys live in api/.env.local as
# LOCAL_DEV_UNKEY_DEMO_KEY / PRODUCTION_UNKEY_DEMO_KEY — copy the matching one
# here. Drives both the REST suite and the SDK client.
PFM_API_KEY=

# --- Optional overrides -------------------------------------------------------

# Platform used by the social-accounts auth-url tests. `bluesky` needs no
# provider credentials configured; switch to e.g. `x` or `facebook` if the
# target project has those app credentials set up.
# PFM_TEST_AUTH_PLATFORM=bluesky

# A real, connected social account id to fully exercise the account-feeds
# endpoint. Without it the suite uses a dummy account and accepts the
# documented gated responses.
# PFM_TEST_FEED_ACCOUNT_ID=
