# PostHog Analytics
POST_HOG_API_KEY=
POST_HOG_API_HOST=

# Crisp Chat
CRISP_WEBSITE_ID=

# Ad pixels — set the same values in dashboard/.env.
# GOOGLE_ADS_TAG_ID is the AW-… value from Tools → Conversions → Diagnostics.
# META_PIXEL_ID is the numeric Dataset ID from Events Manager.
GOOGLE_ADS_TAG_ID=
META_PIXEL_ID=

# Post for Me API (private namespace for CMS reads)
# Base URL of the API, e.g. https://api.postforme.dev (no trailing slash)
POST_FOR_ME_API_URL=
# API key granted the `cms.read` permission in Unkey.
# This is NOT a customer API key — it is authorized for the private
# CMS endpoints only.
POST_FOR_ME_API_KEY=

# Shadcn
SHADCNBLOCKS_API_KEY=
