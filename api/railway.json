{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "dockerfilePath": "/api/Dockerfile"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "startCommand": "node dist/src/main",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "multiRegionConfig": {
      "us-east4-eqdc4a": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 10
  }
}
