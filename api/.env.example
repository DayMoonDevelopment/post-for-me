SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Cloudflare R2 — storage provider (swap in place of Supabase Storage).
# R2_ENDPOINT: https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL: public base URL for the post-media bucket (custom domain or pub-<id>.r2.dev), no trailing slash
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Storage bucket name. Defaults to "post-media" if unset.
# Override per environment (e.g. "post-media-staging") to isolate test data.
MEDIA_BUCKET=

# Direct postgres connection — used by Kysely for schemas not exposed via
# PostgREST (e.g. `stripe`). Local default for `supabase start`:
#   postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

UNKEY_ROOT_KEY=
UNKEY_API_ID=

# PostHog (server-side analytics + feature flags, e.g. storage provider
# selection in storage.factory.ts). Use the SAME PostHog project as
# dashboard/marketing/trigger so events attribute to the same teams/people.
POST_HOG_API_KEY=
POST_HOG_API_HOST=

# Private namespace (internal CMS endpoints) is authorized via Unkey RBAC:
# each route requires a permission query (default `cms.read`, overridable
# per-route via the `@ProtectPrivate({ permissions })` decorator). Grant
# `cms.read` (directly or via a role like `service`) to any key that needs
# to hit `/private/*`. These routes are excluded from the OpenAPI spec.

# Optional: set to "true" in dev/preview to include draft articles
# in `/private/cms/articles` responses.
CMS_SHOW_DRAFTS=

DASHBOARD_APP_URL=http://localhost:5173

TRIGGER_SECRET_KEY=

# Social account feeds
# Caps Facebook `expand=metrics` page size to reduce memory pressure.
# Default is 10 when unset.
FacebookFeedMetricsLimitCap=

# Optional Graph API version override. Defaults to v25.0 when unset.
FACEBOOK_API_VERSION=

# Stripe — used by /private/webhooks/stripe and the manual sync CLI
# (`bun run scripts/stripe-sync.ts --env=path/to/.env`). The webhook
# endpoint is excluded from the OpenAPI spec and authenticated via
# Stripe's signature header rather than Unkey.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# Sentry error monitoring. Disabled automatically unless NODE_ENV=production
# AND SENTRY_DSN is set — so local dev never reports. SENTRY_ENVIRONMENT is
# free-form; set it per hosting target as <env>_<host> (e.g. production_railway,
# production_unkey). Defaults to NODE_ENV when unset. SENTRY_RELEASE is baked
# into the image by the Docker build (commit SHA) — not configured here.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
