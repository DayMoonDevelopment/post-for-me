# PostHog (server-side analytics for the automated upgrade flow).
# Set these in the trigger.dev cloud env. Use the SAME PostHog project as the
# dashboard/marketing so events attribute to the same teams/people.
POST_HOG_API_KEY=
POST_HOG_API_HOST=

# Cloudflare R2 — storage provider (swap in place of Supabase Storage).
# R2_ENDPOINT: https://<account-id>.r2.cloudflarestorage.com
# R2_PUBLIC_URL: public base URL for the post-media bucket (custom domain or pub-<id>.r2.dev), no trailing slash
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_PUBLIC_URL=

# Storage bucket name. Defaults to "post-media" if unset.
# Override per environment (e.g. "post-media-staging") to isolate test data.
MEDIA_BUCKET=
