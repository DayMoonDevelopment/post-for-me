# PostHog (server-side analytics for the automated upgrade flow).
# Set these in the trigger.dev cloud env. Use the SAME PostHog project as the
# dashboard/marketing so events attribute to the same teams/people.
POST_HOG_API_KEY=
POST_HOG_API_HOST=

# Cloudflare R2 — media storage (replaces Supabase Storage for new uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=post-media
R2_PUBLIC_URL=

# Storage provider selection: "r2" (default) or "supabase"
STORAGE_PROVIDER=r2
